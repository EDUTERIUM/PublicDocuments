{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_full_name",
    "email_inputs",
    "course_recommendation"
  ],
  "properties": {
    "candidate_full_name": {
      "type": "string"
    },
    "email_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "motivation_score",
        "motivation_summary",
        "reasoning_score",
        "reasoning_summary",
        "commitment_score",
        "commitment_summary",
        "growth_potential_score",
        "growth_potential_summary",
        "overall_fit_label",
        "overall_summary",
        "career_direction_summary",
        "timeframe_summary"
      ],
      "properties": {
        "motivation_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "motivation_summary": {
          "type": "string"
        },
        "reasoning_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "reasoning_summary": {
          "type": "string"
        },
        "commitment_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "commitment_summary": {
          "type": "string"
        },
        "growth_potential_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "growth_potential_summary": {
          "type": "string"
        },
        "overall_fit_label": {
          "type": "string",
          "enum": [
            "very_low",
            "low",
            "moderate",
            "good",
            "strong"
          ]
        },
        "overall_summary": {
          "type": "string"
        },
        "career_direction_summary": {
          "type": "string"
        },
        "timeframe_summary": {
          "type": "string"
        }
      }
    },
    "course_recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "should_recommend_course",
        "recommended_course_name",
        "recommended_course_url",
        "recommended_discount_code",
        "course_type",
        "recommendation_reason",
        "non_recommendation_reason"
      ],
      "properties": {
        "should_recommend_course": {
          "type": "boolean"
        },
        "recommended_course_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "recommended_course_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "recommended_discount_code": {
          "type": [
            "string",
            "null"
          ]
        },       
        "course_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "recommendation_reason": {
          "type": "string"
        },
        "non_recommendation_reason": {
          "type": "string"
        }
      }
    }
  }
}